{
  "name": "caisse-client",
  "version": "1.0.0",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "test": "node --test tests/",
    "build": "electron-builder --win"
  },
  "build": {
    "appId": "com.epicerie.caisse",
    "productName": "CaisseFacile",
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": "nsis"
    },
    "nsis": {
      "oneClick": true,
      "createDesktopShortcut": true
    }
  },
  "dependencies": {
    "better-sqlite3": "^11.0.0"
  },
  "devDependencies": {
    "@electron/rebuild": "^3.6.0",
    "@noble/hashes": "^1.3.3",
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3"
  }
}
